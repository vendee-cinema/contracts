{
  "name": "@vendee-cinema/contracts",
  "version": "1.2.7",
  "description": "Protobuf definitions and generated TypeScript types",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/src/index.js",
    "./account": "./dist/src/account.js",
    "./auth": "./dist/src/auth.js",
    "./category": "./dist/src/category.js",
    "./media": "./dist/src/media.js",
    "./movie": "./dist/src/movie.js",
    "./theater": "./dist/src/theater.js",
    "./user": "./dist/src/user.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "generate": "protoc -I ./proto ./proto/*.proto --ts_proto_out=./gen/ts --ts_proto_opt=nestJs=true,package=omit,stringEnums=true,unrecognizedEnum=false,outputServices=grpc-js,useOptionals=messages,esModuleInterop=true",
    "prepare": "npm run generate && npm run build"
  },
  "files": [
    "dist",
    "proto",
    "gen"
  ],
  "author": {
    "name": "@bagdenius",
    "email": "bagdenius@gmail.com"
  },
  "license": "ISC",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@nestjs/microservices": "^11.1.16",
    "rxjs": "^7.8.2",
    "ts-proto": "^2.11.4"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "typescript": "^5.9.3"
  }
}
